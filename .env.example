WEB3FORMS_ACCESS_KEY=replace-with-web3forms-access-key
DATABASE_URL=postgres://user:password@host/database?sslmode=require
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
OPENROUTER_API_KEY=optional-for-system-testing
DIFY_API_KEY=replace-with-dify-api-key
DIFY_BASE_URL=https://dify.tissuu.ai/v1
# Use "shared" for alpha if reusing the existing Tissuu/Sysdom knowledge base.
# Use "dedicated" after a separate SimOne corpus exists.
DIFY_KNOWLEDGE_MODE=shared
DIFY_SHARED_KNOWLEDGE_ID=replace-with-existing-knowledge-id
DIFY_SIM_KNOWLEDGE_ID=replace-with-simone-knowledge-id
# Existing Tissuu aliases also accepted for shared alpha reuse:
# DIFY_API_URL=https://dify.tissuu.ai/v1
# DIFY_KB_API_KEY=replace-with-dify-kb-api-key
# DIFY_DATASET_ID=replace-with-existing-dataset-id
